rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Funções auxiliares
    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }

    // Jogadores — leitura pública, escrita própria
    match /players/{uid} {
      allow read:  if isAuth();
      allow write: if isOwner(uid);
    }

    // Cidades — leitura pública autenticada, escrita própria
    match /cities/{cityId} {
      allow read:  if isAuth();
      allow write: if isAuth() && resource.data.playerId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.playerId == request.auth.uid;
    }

    // Mundos — somente leitura para clientes (escrita via serverless)
    match /worlds/{worldId} {
      allow read:  if isAuth();
      allow write: if false;

      match /tiles/{tileId} {
        allow read:  if isAuth();
        allow write: if false;
      }
    }

    // Alianças — leitura pública, membros podem escrever
    match /alliances/{allianceId} {
      allow read:  if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && (
        request.auth.uid in resource.data.members ||
        request.auth.uid == resource.data.leaderId
      );
    }

    // Partidas — somente leitura (escritas via serverless)
    match /matches/{matchId} {
      allow read:  if isAuth();
      allow write: if false;
    }
  }
}
